<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VNO.Server.ViewModels"
             x:Class="VNO.Server.Views.ChatPageView"
             x:DataType="vm:ChatViewModel">

    <DockPanel Margin="{DynamicResource CPagePad}">

        <!-- tab strip -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource CBg2}" CornerRadius="8"
                Padding="3" HorizontalAlignment="Left" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button Classes="tab" Classes.active="{Binding IsOocTab}" Content="OOC Chat"
                        Command="{Binding SelectTabCommand}" CommandParameter="ooc" />
                <Button Classes="tab" Classes.active="{Binding IsIcTab}" Content="In-Character"
                        Command="{Binding SelectTabCommand}" CommandParameter="ic" />
                <Button Classes="tab" Classes.active="{Binding IsEventsTab}" Content="Event Log"
                        Command="{Binding SelectTabCommand}" CommandParameter="events" />
            </StackPanel>
        </Border>

        <Panel>

            <!-- OOC chat -->
            <Border Classes="card" IsVisible="{Binding IsOocTab}">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Padding="16,12"
                            BorderBrush="{DynamicResource CBorder}" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding OocInput}" PlaceholderText="Speak as Server..."
                                     CornerRadius="18" Padding="14,9">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SendOocCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                            <Button Grid.Column="1" Classes="primary" Content="Send"
                                    CornerRadius="18" Margin="10,0,0,0"
                                    Command="{Binding SendOocCommand}" />
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="OocScroll">
                        <ItemsControl ItemsSource="{Binding OocMessages}" Margin="16">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:OocItemViewModel">
                                    <Panel>
                                        <!-- player message, left aligned -->
                                        <StackPanel HorizontalAlignment="Left" MaxWidth="520"
                                                    IsVisible="{Binding !IsServer}">
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        Margin="0,0,0,2">
                                                <TextBlock FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource CText2}"
                                                           Text="{Binding Sender}" />
                                                <TextBlock Classes="faint" FontSize="10"
                                                           Text="{Binding TimeText}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Border Background="{DynamicResource CBg4}"
                                                    CornerRadius="18,18,18,4" Padding="14,10"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Classes="body" TextWrapping="Wrap"
                                                           Text="{Binding Text}" />
                                            </Border>
                                        </StackPanel>
                                        <!-- server message, right aligned -->
                                        <StackPanel HorizontalAlignment="Right" MaxWidth="520"
                                                    IsVisible="{Binding IsServer}">
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        Margin="0,0,0,2" HorizontalAlignment="Right">
                                                <TextBlock Classes="faint" FontSize="10"
                                                           Text="{Binding TimeText}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource CAccent}"
                                                           Text="{Binding Sender}" />
                                            </StackPanel>
                                            <Border Background="{DynamicResource CAccentMuted}"
                                                    CornerRadius="18,18,4,18" Padding="14,10"
                                                    HorizontalAlignment="Right">
                                                <TextBlock Classes="body" TextWrapping="Wrap"
                                                           Text="{Binding Text}" />
                                            </Border>
                                        </StackPanel>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- in character chat, read only -->
            <Border Classes="card" IsVisible="{Binding IsIcTab}">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Padding="16,12"
                            BorderBrush="{DynamicResource CBorder}" BorderThickness="0,1,0,0">
                        <TextBlock Classes="faint" FontSize="12" HorizontalAlignment="Center"
                                   Text="In-character chat is read-only from this console" />
                    </Border>
                    <ScrollViewer x:Name="IcScroll">
                        <ItemsControl ItemsSource="{Binding IcMessages}" Margin="16">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:IcItemViewModel">
                                    <StackPanel HorizontalAlignment="Left" MaxWidth="600">
                                        <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,0,0,2">
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CBlue}"
                                                       Text="{Binding Character}" />
                                            <TextBlock Grid.Column="1" Classes="faint" FontSize="10"
                                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                                       Text="{Binding Player}" />
                                            <TextBlock Grid.Column="2" Classes="faint" FontSize="10"
                                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                                       Text="{Binding TimeText}" />
                                        </Grid>
                                        <Border Background="{DynamicResource CBg4}"
                                                CornerRadius="16,16,16,4" Padding="14,10"
                                                HorizontalAlignment="Left">
                                            <TextBlock Classes="body" FontStyle="Italic"
                                                       TextWrapping="Wrap" Text="{Binding Text}" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- event log -->
            <Border Classes="card" IsVisible="{Binding IsEventsTab}">
                <ScrollViewer x:Name="EventsScroll">
                    <ItemsControl ItemsSource="{Binding Events}" Margin="16,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:EventItemViewModel">
                                <Grid ColumnDefinitions="52,Auto,*" Margin="0,4">
                                    <TextBlock Classes="mono faint" FontSize="12"
                                               Text="{Binding TimeText}" />
                                    <Ellipse Grid.Column="1" Classes="dot small"
                                             Classes.on="{Binding IsJoin}"
                                             Classes.mod="{Binding IsModeration}"
                                             Classes.err="{Binding IsError}"
                                             Margin="10,4,0,0" VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="2" Classes="mono muted" FontSize="12"
                                               TextWrapping="Wrap" Margin="10,0,0,0"
                                               Text="{Binding Text}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Panel>
    </DockPanel>
</UserControl>
