<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VNO.Server.ViewModels"
             x:Class="VNO.Server.Views.AppearancePageView"
             x:DataType="vm:AppearanceViewModel">

    <ScrollViewer>
        <StackPanel Margin="{DynamicResource CPagePad}" Spacing="28" MaxWidth="560"
                    HorizontalAlignment="Left">

            <!-- theme -->
            <StackPanel>
                <TextBlock Classes="h1" Text="Theme" />
                <TextBlock Classes="dim" Margin="0,4,0,14"
                           Text="Choose light or dark mode for the console." />
                <Border Background="{DynamicResource CBg2}" CornerRadius="8" Padding="3"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <Button Classes="tab" Classes.active="{Binding IsDark}" Content="Dark"
                                Padding="20,7" Command="{Binding SetDarkCommand}" />
                        <Button Classes="tab" Classes.active="{Binding !IsDark}" Content="Light"
                                Padding="20,7" Command="{Binding SetLightCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- accent -->
            <StackPanel>
                <TextBlock Classes="h1" Text="Accent Color" />
                <TextBlock Classes="dim" Margin="0,4,0,14"
                           Text="This color appears on active elements, buttons, and highlights." />
                <ItemsControl ItemsSource="{Binding Swatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AccentSwatchViewModel">
                            <Button Classes="ghost" Padding="0" CornerRadius="8"
                                    Command="{Binding SelectCommand}">
                                <Border Width="34" Height="34" CornerRadius="8"
                                        Background="{Binding Brush}"
                                        BorderThickness="2"
                                        Classes="swatch"
                                        Classes.picked="{Binding IsSelected}">
                                    <Border.Styles>
                                        <Style Selector="Border.swatch">
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                        </Style>
                                        <Style Selector="Border.swatch.picked">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource CText0}" />
                                        </Style>
                                    </Border.Styles>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- density -->
            <StackPanel>
                <TextBlock Classes="h1" Text="Density" />
                <TextBlock Classes="dim" Margin="0,4,0,14"
                           Text="Compact mode tightens spacing for more information density." />
                <Border Background="{DynamicResource CBg2}" CornerRadius="8" Padding="3"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <Button Classes="tab" Classes.active="{Binding !IsCompact}" Content="Comfortable"
                                Padding="20,7" Command="{Binding SetComfortableCommand}" />
                        <Button Classes="tab" Classes.active="{Binding IsCompact}" Content="Compact"
                                Padding="20,7" Command="{Binding SetCompactCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- presets -->
            <StackPanel>
                <TextBlock Classes="h1" Text="Presets" />
                <TextBlock Classes="dim" Margin="0,4,0,14"
                           Text="Quick-apply a saved look." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="subtle" Content="Midnight Gold"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="midnight" />
                    <Button Classes="subtle" Content="Ocean"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="ocean" />
                    <Button Classes="subtle" Content="Rosé"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="rose" />
                    <Button Classes="subtle" Content="Daylight"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="daylight" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
