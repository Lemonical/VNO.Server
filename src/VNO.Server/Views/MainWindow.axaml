<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:vm="using:VNO.Server.ViewModels"
        xmlns:views="using:VNO.Server.Views"
        x:Class="VNO.Server.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="620"
        Background="{DynamicResource CBg0}"
        FontSize="{DynamicResource CFontBase}"
        Title="Visual Novel Online Server">

    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding ActiveModal.CancelCommand}" />
    </Window.KeyBindings>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:PlayersViewModel">
            <views:PlayersPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:ChatViewModel">
            <views:ChatPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:ConfigurationViewModel">
            <views:ConfigurationPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:BansViewModel">
            <views:BansPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:AppearanceViewModel">
            <views:AppearancePageView />
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>

        <!-- shell -->
        <DockPanel>

            <!-- sidebar -->
            <Border DockPanel.Dock="Left"
                    Width="{Binding SidebarWidth}"
                    Background="{DynamicResource CBg1}"
                    BorderBrush="{DynamicResource CBorder}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- signed in operator account -->
                    <Border DockPanel.Dock="Top" Padding="14,16"
                            BorderBrush="{DynamicResource CBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="30" Height="30" CornerRadius="8"
                                    Background="{DynamicResource CAccent}">
                                <i:Icon Value="fa-solid fa-user" FontSize="13"
                                        Foreground="{DynamicResource CAccentFg}" />
                            </Border>
                            <TextBlock Text="{Binding AccountName}" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding SidebarExpanded}" />
                        </StackPanel>
                    </Border>

                    <!-- bottom controls -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8" Spacing="4">
                        <Button Classes="navitem" Command="{Binding ToggleThemeCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <i:Icon Value="fa-solid fa-moon" FontSize="15" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Text="{Binding ThemeLabel}" FontSize="12"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="navitem" Command="{Binding ToggleSidebarCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <i:Icon Value="fa-solid fa-chevron-left" FontSize="15" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Text="Collapse" FontSize="12"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- navigation -->
                    <StackPanel Margin="8" Spacing="2">

                        <Button Classes="navitem" Classes.active="{Binding IsDashboardActive}"
                                Command="{Binding NavigateCommand}" CommandParameter="dashboard">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <i:Icon Value="fa-solid fa-gauge-high" FontSize="15" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Grid.Column="1" Text="Dashboard" FontWeight="Medium"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                            </Grid>
                        </Button>

                        <Button Classes="navitem" Classes.active="{Binding IsPlayersActive}"
                                Command="{Binding NavigateCommand}" CommandParameter="players">
                            <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                <i:Icon Value="fa-solid fa-users" FontSize="14" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Grid.Column="1" Text="Players" FontWeight="Medium"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                                <Border Grid.Column="2" CornerRadius="10" Padding="6,1"
                                        Background="{DynamicResource CAccentMuted}"
                                        VerticalAlignment="Center">
                                    <Border.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="SidebarExpanded" />
                                            <Binding Path="HasPlayers" />
                                        </MultiBinding>
                                    </Border.IsVisible>
                                    <TextBlock Text="{Binding PlayerCount}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource CAccent}" />
                                </Border>
                            </Grid>
                        </Button>

                        <Button Classes="navitem" Classes.active="{Binding IsChatActive}"
                                Command="{Binding NavigateCommand}" CommandParameter="chat">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <i:Icon Value="fa-solid fa-comments" FontSize="14" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Grid.Column="1" Text="Chat" FontWeight="Medium"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                            </Grid>
                        </Button>

                        <Button Classes="navitem" Classes.active="{Binding IsConfigurationActive}"
                                Command="{Binding NavigateCommand}" CommandParameter="configuration">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <i:Icon Value="fa-solid fa-sliders" FontSize="15" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Grid.Column="1" Text="Configuration" FontWeight="Medium"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                            </Grid>
                        </Button>

                        <Button Classes="navitem" Classes.active="{Binding IsBansActive}"
                                Command="{Binding NavigateCommand}" CommandParameter="bans">
                            <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                <i:Icon Value="fa-solid fa-ban" FontSize="15" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Grid.Column="1" Text="Bans" FontWeight="Medium"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                                <Border Grid.Column="2" CornerRadius="10" Padding="6,1"
                                        Background="{DynamicResource CRedMuted}"
                                        VerticalAlignment="Center">
                                    <Border.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="SidebarExpanded" />
                                            <Binding Path="HasBans" />
                                        </MultiBinding>
                                    </Border.IsVisible>
                                    <TextBlock Text="{Binding BanCount}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource CRed}" />
                                </Border>
                            </Grid>
                        </Button>

                        <Button Classes="navitem" Classes.active="{Binding IsAppearanceActive}"
                                Command="{Binding NavigateCommand}" CommandParameter="appearance">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <i:Icon Value="fa-solid fa-palette" FontSize="14" Width="18"
                                        Foreground="{Binding $parent[Button].Foreground}" />
                                <TextBlock Grid.Column="1" Text="Appearance" FontWeight="Medium"
                                           Foreground="{Binding $parent[Button].Foreground}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsVisible="{Binding SidebarExpanded}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- header -->
            <Border DockPanel.Dock="Top" Height="52"
                    Background="{DynamicResource CBg1}"
                    BorderBrush="{DynamicResource CBorder}" BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="subtle" Content="Send Notice"
                            VerticalAlignment="Center"
                            Command="{Binding SendNoticeCommand}" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                                Margin="16,0,0,0" VerticalAlignment="Center">
                        <Ellipse Classes="dot" Classes.on="{Binding IsOnline}" />
                        <TextBlock Classes="mono" Text="{Binding HeaderStatusText}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource CText2}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- status bar -->
            <Border DockPanel.Dock="Bottom" Height="30"
                    Background="{DynamicResource CBg1}"
                    BorderBrush="{DynamicResource CBorder}" BorderThickness="0,1,0,0"
                    Padding="20,0">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Ellipse Classes="dot" Classes.on="{Binding IsOnline}" />
                            <TextBlock Classes="dim" FontSize="11" Text="{Binding StatusLabel}" />
                        </StackPanel>
                        <TextBlock Classes="faint" Text="·" />
                        <TextBlock Classes="dim" FontSize="11" Text="{Binding AuthLabel, StringFormat='Auth: {0}'}" />
                        <TextBlock Classes="faint" Text="·" />
                        <TextBlock Classes="dim" FontSize="11" Text="{Binding PlayerCountText}" />
                        <TextBlock Classes="faint" Text="·" />
                        <TextBlock Classes="dim" FontSize="11" Text="{Binding UptimeText}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Classes="mono" FontSize="10"
                               Foreground="{DynamicResource CText3}"
                               Text="{Binding ApplicationVersionLabel}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- current page -->
            <ContentControl Content="{Binding CurrentPage}" />
        </DockPanel>

        <!-- toasts -->
        <ItemsControl ItemsSource="{Binding Toasts}"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,60,20,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="8" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ToastViewModel">
                    <Border Background="{DynamicResource CBg3}"
                            BorderBrush="{DynamicResource CBorderStrong}" BorderThickness="1"
                            CornerRadius="8" Padding="16,10" MinWidth="240"
                            BoxShadow="0 4 16 0 #40000000">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Ellipse Classes="dot mod" VerticalAlignment="Center"
                                     Classes.on="{Binding IsSuccess}"
                                     Classes.err="{Binding IsError}" />
                            <TextBlock Grid.Column="1" Classes="body" Text="{Binding Message}"
                                       Margin="10,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                       MaxWidth="320" />
                            <Button Grid.Column="2" Classes="ghost" Content="×" FontSize="14"
                                    Padding="4,0" VerticalAlignment="Center"
                                    Command="{Binding DismissCommand}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- modal overlay -->
        <Panel IsVisible="{Binding IsModalOpen}" Background="{DynamicResource CScrim}">
            <Border Width="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource CBg3}"
                    BorderBrush="{DynamicResource CBorderStrong}" BorderThickness="1"
                    CornerRadius="12" Padding="28"
                    BoxShadow="0 12 40 0 #4D000000"
                    DataContext="{Binding ActiveModal}"
                    x:DataType="vm:ModalViewModel">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Request.Title}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Classes="dim" FontSize="13" TextWrapping="Wrap"
                                   Text="{Binding Request.Description}" />
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding Request.ShowCredentials}">
                        <TextBlock Classes="dim" Text="Username" />
                        <TextBox Text="{Binding Username}" PlaceholderText="Account name" />
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding Request.ShowCredentials}">
                        <TextBlock Classes="dim" Text="Password" />
                        <TextBox Text="{Binding Password}" PasswordChar="●"
                                 PlaceholderText="Password" />
                    </StackPanel>

                    <CheckBox Content="Remember me" IsChecked="{Binding Remember}"
                              IsVisible="{Binding Request.ShowRemember}" />

                    <StackPanel Spacing="6" IsVisible="{Binding Request.ShowReason}">
                        <TextBlock Classes="dim" Text="Reason" />
                        <TextBox Text="{Binding Reason}" PlaceholderText="Optional reason..." />
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding Request.ShowDuration}">
                        <TextBlock Classes="dim" Text="Duration" />
                        <ComboBox ItemsSource="{Binding Durations}"
                                  SelectedItem="{Binding SelectedDuration}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding Request.ShowMessage}">
                        <TextBlock Classes="dim" Text="Message" />
                        <TextBox Text="{Binding Message}" PlaceholderText="Type your broadcast notice..."
                                 AcceptsReturn="True" MinHeight="72" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right"
                                Margin="0,8,0,0">
                        <Button Classes="subtle" Content="Cancel" Command="{Binding CancelCommand}"
                                IsVisible="{Binding Request.AllowCancel}" />
                        <Button Classes="primary" Content="{Binding Request.ConfirmLabel}"
                                IsVisible="{Binding !Request.IsDestructive}"
                                Command="{Binding ConfirmCommand}" />
                        <Button Classes="danger" Content="{Binding Request.ConfirmLabel}"
                                IsVisible="{Binding Request.IsDestructive}"
                                Command="{Binding ConfirmCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
</Window>
